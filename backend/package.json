{
  "name": "nutriai-fit-backend",
  "version": "1.0.0",
  "description": "NutriAI Fit — Backend API REST",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
