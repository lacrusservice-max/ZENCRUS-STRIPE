# ============================================================
# NutriAI Fit — Variables de Entorno
# Copiar a .env y completar los valores reales
# NUNCA commitear el archivo .env al repositorio
# ============================================================

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_NAME=NutriAI-Fit
APP_VERSION=1.0.0
APP_SECRET=change_this_to_a_random_64_char_string

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_secret
JWT_REFRESH_SECRET=change_this_to_another_random_64_char_secret
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── Supabase (dejar vacío hasta conectar) ───────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── DeepSeek AI (placeholder — integrar en fase 2) ──────────
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="NutriAI Fit <noreply@nutriaifit.com>"

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_MONTHLY=price_your_monthly_price_id
STRIPE_PRICE_ANNUAL_INDIVIDUAL=price_your_annual_individual_price_id
STRIPE_PRICE_ANNUAL_DUO=price_your_annual_duo_price_id
STRIPE_PRICE_ANNUAL_FAMILIAR=price_your_annual_familiar_price_id
STRIPE_PRICE_EXTRA_MEMBER=price_your_extra_member_price_id

# ── MercadoPago ──────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=your_mp_access_token
MERCADOPAGO_PUBLIC_KEY=your_mp_public_key
MERCADOPAGO_WEBHOOK_SECRET=your_mp_webhook_secret

# ── Firebase (Push Notifications) ───────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_SERVER_KEY=your_firebase_server_key

# ── Redis (Rate Limiting & Cache) ───────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# ── Seguridad ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5
ENCRYPTION_KEY=32_bytes_hex_string_for_aes256_encryption
SALT_ROUNDS=12

# ── URLs ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Sentry (Monitoreo de errores) ────────────────────────────
SENTRY_DSN=https://your_key@sentry.io/your_project

# ── Almacenamiento ───────────────────────────────────────────
STORAGE_BUCKET=nutriaifit-assets
MAX_FILE_SIZE_MB=5
